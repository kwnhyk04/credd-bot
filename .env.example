NODE_ENV=development
BOT_TOKEN=
CLIENT_ID=
DATABASE_URL=
DEV_IDS=

# Required in production. Used to load assets from Cloudflare R2 by public URL.
# Example: https://pub-xxxx.r2.dev
ASSET_BASE_URL=
# Optional. Change this when replacing R2 assets to bypass cached URLs.
ASSET_VERSION=

# Database TLS — set for any remote/hosted Postgres (leave both blank only when
# Postgres runs on the same host).
# PGSSL_CA: path to the provider's CA certificate → encrypts AND verifies the server
#           (preferred; takes precedence over PGSSL).
# PGSSL=require: encrypts without CA verification (fallback when no CA file is available;
#           equivalent to libpq sslmode=require).
PGSSL=
PGSSL_CA=

# Optional Postgres pool guardrails (milliseconds unless noted). Defaults shown;
# leave blank to use them. These make stalled connections/locks error out instead
# of hanging forever (prevents per-user battle deadlocks).
# PG_POOL_MAX=10               (connections)
# PG_CONNECT_TIMEOUT_MS=10000
# PG_IDLE_TIMEOUT_MS=30000
# PG_QUERY_TIMEOUT_MS=30000
# PG_STATEMENT_TIMEOUT_MS=25000
# PG_IDLE_TXN_TIMEOUT_MS=60000

# Optional R2 WRITE credentials (S3 API) — enable the canvas render-once cache
# (src/utils/canvasCache.js): profile/stats/equipment/quest images upload to the
# bucket once and are then served by URL (zero Discord-upload egress).
# R2_BUCKET must be the bucket ASSET_BASE_URL serves. Leave blank to disable
# (bot falls back to attaching, current behavior).
# Production: these R2 write credentials are required on Railway unless
# ALLOW_DISCORD_IMAGE_ATTACHMENTS=true is intentionally set.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Days a cache object may sit unused before the 6h sweep evicts it (default 14).
CANVAS_CACHE_MAX_AGE_DAYS=
# Throttle canvas_cache last_used_at writes per rendered cache key.
CANVAS_CACHE_TOUCH_THROTTLE_MS=300000

# Production egress safety. Keep false/blank on Railway. Setting true allows
# Discord image attachment fallbacks and can generate large Railway egress.
ALLOW_DISCORD_IMAGE_ATTACHMENTS=false
BANDWIDTH_LOGS=false
PERFORMANCE_LOGS=false

# Production image optimization. WebP is preferred for generated opaque images;
# transparent renderers keep alpha where required and fall back safely if needed.
IMAGE_OUTPUT_FORMAT=webp
IMAGE_WEBP_QUALITY=65
IMAGE_COMPRESSION_AGGRESSIVE=true
IMAGE_RENDER_CONCURRENCY=1

# Lightweight production resource snapshots. Enable on Railway while optimizing,
# then leave on only if log volume is acceptable.
RESOURCE_LOGS=true
RESOURCE_LOG_INTERVAL_MS=300000

# Short-lived profile URL reuse. This stores URLs/signatures only, not image buffers.
PROFILE_IMAGE_CACHE_TTL_MS=60000
PROFILE_IMAGE_CACHE_MAX=50

# Remote asset cache controls. Disk cache uses .cache/assets, which is ignored by Git.
ASSET_DISK_CACHE_ENABLED=true
ASSET_MEMORY_CACHE_MAX=100

# DB/write and selection-pool production tuning.
USER_ACTIVITY_WRITE_THROTTLE_MS=60000
SELECTION_POOL_CACHE_TTL_MS=300000
SELECTION_POOL_CACHE_MAX=50

# Boss runtime log cache caps. Damage/rewards remain stored in the database.
BOSS_LOG_CACHE_MAX_ATTACKERS=50
BOSS_LOG_CACHE_MAX_EVENTS_PER_ATTACKER=20
BOSS_IMAGE_REFRESH_DEBOUNCE_MS=15000
BOSS_IMAGE_REFRESH_ENABLED=true
CASINO_ENABLED=false

# Optional slash-command deployment override. Leave blank for global deploy.
GUILD_IDS=
# Startup sync registers slash commands to GUILD_IDS, or to every guild the bot is in
# when GUILD_IDS is blank. Set false only if you deploy commands manually.
SYNC_SLASH_COMMANDS_ON_START=true

# Optional supporter/tester defaults. Keep false/blank for production unless intentionally enabled.
BETA_MODE=false
DEV_ACCOUNT_IDS=
# Dev/test only. When true, DEV_ACCOUNT_IDS can view/equip all class-valid avatars without purchase.
# Defaults on outside NODE_ENV=production, or on Railway environments not named production/prod.
AVATAR_DEV_UNLOCKS=false

# Dangerous dev-only overrides. Keep false in production.
ALLOW_DESTRUCTIVE_DEV_COMMANDS=false
ALLOW_HIGH_VALUE_DEV_COMMANDS=false
ALLOW_SUPPORTER_DEV_COMMANDS=false
ALLOW_LIVE_EVENT_DEV_COMMANDS=false
