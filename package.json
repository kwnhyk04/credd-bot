{
  "name": "credd-bot",
  "version": "1.0.0",
  "description": "Credd — The Last Believer RPG Discord Bot",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "selftest": "node scripts/battle-selftest.js",
    "selftest:weapons": "node scripts/weapon-passive-selftest.js",
    "selftest:bestow": "node scripts/bestow-limit-selftest.js",
    "selftest:patch": "node scripts/requested-patch-selftest.js",
    "selftest:memory": "node --expose-gc scripts/memory-selftest.js",
    "selftest:memory:casino": "node --expose-gc scripts/casino-memory-selftest.js",
    "selftest:memory:integrated": "node scripts/integrated-image-memory-selftest.js",
    "selftest:canvas": "node scripts/canvas-runtime-selftest.js",
    "benchmark:canvas-memory": "node scripts/canvas-native-memory-benchmark.js",
    "selftest:telemetry": "node scripts/network-telemetry-selftest.js",
    "selftest:asset-cache": "node scripts/asset-disk-cache-selftest.js",
    "selftest:skin-r2": "node scripts/skin-r2-selftest.js",
    "selftest:level-rewards": "node scripts/level-rewards-selftest.js",
    "selftest:compensation": "node scripts/compensation-selftest.js",
    "selftest:crd-shop": "node scripts/crd-shop-selftest.js",
    "selftest:crd-bag-use": "node scripts/crd-bag-use-selftest.js",
    "selftest:class-change": "node scripts/class-change-selftest.js",
    "selftest:genesis-avatar": "node scripts/genesis-avatar-selftest.js",
    "selftest:genesis-enhancement": "node scripts/genesis-enhancement-selftest.js",
    "selftest:celestial-rank": "node scripts/celestial-rank-selftest.js",
    "selftest:genesis-update": "npm run selftest:level-rewards && npm run selftest:compensation && npm run selftest:crd-shop && npm run selftest:crd-bag-use && npm run selftest:class-change && npm run selftest:genesis-avatar && npm run selftest:genesis-enhancement && npm run selftest:celestial-rank",
    "selftest:schema": "node scripts/schema-drift-selftest.js",
    "selftest:lifecycle": "node scripts/lifecycle-guard-selftest.js",
    "selftest:full": "npm run selftest && npm run selftest:weapons && npm run selftest:bestow && npm run selftest:genesis-update && npm run selftest:patch && npm run selftest:telemetry && npm run selftest:asset-cache && npm run selftest:skin-r2 && npm run selftest:canvas && npm run selftest:schema && npm run selftest:lifecycle && node scripts/help-selftest.js && node scripts/casino-selftest.js",
    "preflight": "node scripts/production-preflight.js",
    "preflight:prod": "node scripts/production-preflight.js --prod",
    "compensate:levels:dry": "node scripts/level-reward-compensation.js --dry-run",
    "compensate:levels": "node scripts/level-reward-compensation.js --execute"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "discord.js": "^14.19.0",
    "dotenv": "^16.4.7",
    "node-cron": "^3.0.3",
    "pg": "^8.13.1",
    "sharp": "^0.35.1"
  },
  "devDependencies": {
    "supabase": "^2.109.0"
  },
  "overrides": {
    "undici": "^6.26.1",
    "uuid": "^11.1.1"
  }
}
