{
  "name": "credd-bot",
  "version": "1.0.0",
  "description": "Credd — The Last Believer RPG Discord Bot",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "selftest": "node scripts/battle-selftest.js",
    "selftest:full": "npm run selftest && node scripts/help-selftest.js && node scripts/casino-selftest.js",
